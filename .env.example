# --- Transcript source (Financial Modeling Prep) ---
# Free tier covers a handful of tickers/quarters; sign up at financialmodelingprep.com
FMP_API_KEY=your_fmp_key_here

# --- LLM providers (set at least one) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Defaults (override per-run via CLI) ---
LLM_PROVIDER=anthropic            # anthropic | openai
ANTHROPIC_MODEL=claude-haiku-4-5-20251001  # bulk pass; use claude-opus-4-7 for deeper
OPENAI_MODEL=gpt-4o-mini

# Cache directory (transcripts + LLM responses)
CACHE_DIR=./cache
